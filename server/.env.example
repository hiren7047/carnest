NODE_ENV=development
PORT=4000

# --- MySQL (required) ---
# Pehla `sql/init-mysql.sql` run karo ke `CREATE DATABASE carnest` thai jai.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=carnest
DB_USER=root
DB_PASSWORD=

# India IST — dates/times in API (change if server runs in UTC only)
DB_TIMEZONE=+05:30

# Connection pool (optional tuning under load)
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Set true for managed cloud MySQL (RDS, Azure, etc.) that requires TLS
DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=true

# Set false to hide SQL logs in development
# DB_LOGGING=false

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:8080
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:4000

# Set true with npm run seed to wipe cars (and related bookings/saved) and re-seed
# FORCE_RESEED_CARS=false

# Optional Cloudinary — if set, POST /api/upload uses Cloudinary instead of disk
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
