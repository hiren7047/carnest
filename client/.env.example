# Leave empty in development to use Vite proxy to the API (see vite.config.ts).
# For production builds, set the full API origin, e.g. https://api.example.com
VITE_API_URL=

# Country code + number, no + (e.g. 919876543210)
VITE_WHATSAPP_NUMBER=919876543210

# Display phone (e.g. +91 98765 43210) and tel: digits for the call FAB / contact
VITE_PUBLIC_PHONE_DISPLAY=+91 98765 43210
VITE_PUBLIC_PHONE_TEL=919876543210
